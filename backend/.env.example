# Copy to .env and adjust. See root README.md.

# PostgreSQL (docker-compose + official image)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=oneshot_fantasy
POSTGRES_PUBLISH_PORT=5432

# Python worker (SQLAlchemy async) — from host, use 127.0.0.1 and POSTGRES_PUBLISH_PORT (Symfony uses postgresql:// without +asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/oneshot_fantasy
