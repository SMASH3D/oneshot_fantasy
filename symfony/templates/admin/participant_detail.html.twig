{% extends '@EasyAdmin/crud/detail.html.twig' %}

{% block main %}
    {{ parent() }}

    <div class="mt-5">
        <h3>Statistics Overview</h3>
        
        {# Prepare Radar stats data using Percentages of Maximum #}
        {% set template_stats = {'points': 0, 'assists': 0, 'rebounds': 0, 'steals': 0, 'blocks': 0, 'turnovers': 0, 'minutes_played': 0, 'games_played': 0, 'plus_minus': 0} %}
        {% set radar_stats = template_stats %}
        {% set benchman_radar_stats = template_stats %}
        {% set radar_raw = template_stats %}
        {% set benchman_raw = template_stats %}

        {% for stat in entity.instance.stats %}
            {% set code = stat.statDefinition.code %}
            {% if code in radar_stats|keys %}
                {% set max_avg = max_stats[code].average|default(1) %}
                {% if max_avg == 0 %}{% set max_avg = 1 %}{% endif %}
                
                {% set stat_avg = stat.averageValue|default(0) %}
                {% set stat_tot = stat.totalValue|default(0) %}
                {% set pct = (stat_avg / max_avg) * 100 %}
                
                {% set radar_stats = radar_stats|merge({(code): pct}) %}
                {% set radar_raw = radar_raw|merge({(code): {'total': stat_tot, 'average': stat_avg}}) %}
            {% endif %}
        {% endfor %}

        {% for code, val in benchman_radar_stats %}
            {% set max_avg = max_stats[code].average|default(1) %}
            {% if max_avg == 0 %}{% set max_avg = 1 %}{% endif %}
            
            {% set bench_avg = benchman_stats[code].average|default(0) %}
            {% set bench_pct = (bench_avg / max_avg) * 100 %}
            
            {% set benchman_radar_stats = benchman_radar_stats|merge({(code): bench_pct}) %}
            {% set benchman_raw = benchman_raw|merge({(code): bench_avg}) %}
        {% endfor %}

        <div class="row align-items-center">
            <div class="col-md-5">
                <table class="table table-striped table-sm">
                    <thead>
                        <tr>
                            <th>Statistic</th>
                            <th>Total</th>
                            <th>Avg</th>
                            <th>Max Total</th>
                            <th>Max Avg</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for code in ['points', 'assists', 'rebounds', 'steals', 'blocks', 'turnovers', 'minutes_played', 'games_played', 'plus_minus'] %}
                            <tr>
                                <td>{{ code|replace({'_': ' '})|title }}</td>
                                <td>{{ radar_raw[code].total|default(0)|number_format(1) }}</td>
                                <td>{{ radar_raw[code].average|default(0)|number_format(1) }}</td>
                                <td>{{ max_stats[code].total|default(0)|number_format(1) }}</td>
                                <td>{{ max_stats[code].average|default(0)|number_format(1) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="col-md-7">
                <div style="width: 100%; height: 450px; max-width: 100%; margin: 0 auto;">
                    <canvas id="participantRadarChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <hr class="mt-5 mb-5">

    <div class="mt-5">
        <h3>Simulated Preset Scores</h3>
        
        <div class="form-group mb-3">
            <label for="preset-selector"><strong>Select Scoring Preset:</strong></label>
            <select id="preset-selector" class="form-control">
                <option value="">-- Choose a Preset --</option>
                {% for preset in scoring_presets|default([]) %}
                    <option value="{{ preset.scoringConfigHash }}">{{ preset.name }}</option>
                {% endfor %}
            </select>
        </div>

        {# Prepare nested dictionary of existing precomputed scores #}
        {% set scores_json = {} %}
        {% for score in entity.instance.aggregatedScores %}
            {% set scores_json = scores_json|merge({
                (score.scoreConfigHash): {
                    'totalScore': score.totalScore,
                    'breakdown': score.breakdown
                }
            }) %}
        {% endfor %}

        <div id="score-display-container" style="display: none;" class="card mt-3">
            <div class="card-body">
                <h4 class="card-title text-primary">Total Score: <span id="score-total-value"></span></h4>
                <h5 class="mt-4">Breakdown:</h5>
                <pre id="score-breakdown-value" class="bg-light p-3 border rounded"></pre>
            </div>
        </div>
        
        <div id="score-missing-container" style="display: none;" class="alert alert-warning mt-3">
            This preset's hash hasn't been computed for this participant yet! Ensure the backend batch python scripts have successfully run for this precise configuration.
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // 1. Render Radar Chart
            const ctx = document.getElementById('participantRadarChart').getContext('2d');
            const radarData = {{ radar_stats|json_encode|raw }};
            const benchmanData = {{ benchman_radar_stats|json_encode|raw }};
            const radarRaw = {{ radar_raw|json_encode|raw }};
            const benchmanRaw = {{ benchman_raw|json_encode|raw }};
            const maxStats = {{ max_stats|default({})|json_encode|raw }};
            
            const statKeys = ['points', 'assists', 'rebounds', 'steals', 'blocks', 'turnovers', 'minutes_played', 'games_played', 'plus_minus'];
            const statLabels = statKeys.map(k => k.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()));

            new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: statLabels,
                    datasets: [
                        {
                            label: 'Player Performance vs Max (%)',
                            data: statKeys.map(k => radarData[k] || 0),
                            backgroundColor: 'rgba(54, 162, 235, 0.2)',
                            borderColor: 'rgba(54, 162, 235, 1)',
                            pointBackgroundColor: 'rgba(54, 162, 235, 1)',
                            pointBorderColor: '#fff',
                            pointHoverBackgroundColor: '#fff',
                            pointHoverBorderColor: 'rgba(54, 162, 235, 1)',
                            borderWidth: 2
                        },
                        {
                            label: 'League Average / Baseline (%)',
                            data: statKeys.map(k => benchmanData[k] || 0),
                            backgroundColor: 'rgba(255, 99, 132, 0.2)',
                            borderColor: 'rgba(255, 99, 132, 1)',
                            pointBackgroundColor: 'rgba(255, 99, 132, 1)',
                            pointBorderColor: '#fff',
                            pointHoverBackgroundColor: '#fff',
                            pointHoverBorderColor: 'rgba(255, 99, 132, 1)',
                            borderWidth: 2
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            beginAtZero: true,
                            max: 100, // Enforce normalized percentage limits gracefully
                            ticks: {
                                display: false, // hide the radar chart scale numbers
                                stepSize: 20
                            }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let key = statKeys[context.dataIndex];
                                    let maxVal = maxStats[key]?.average || 1;
                                    let rawVal = context.datasetIndex === 0 ? radarRaw[key]?.average : benchmanRaw[key];
                                    
                                    let percentage = context.raw.toFixed(1).replace('.', ',');
                                    let rawFormatted = parseFloat(rawVal || 0).toFixed(1).replace('.', ',');
                                    let maxFormatted = parseFloat(maxVal).toFixed(2).replace('.', ',');
                                    
                                    return percentage + '% (' + rawFormatted + ' vs ' + maxFormatted + ')';
                                }
                            }
                        }
                    }
                }
            });

            // 2. Interactive Score Displays
            const aggregatedScores = {{ scores_json|json_encode|raw }};
            const presetSelector = document.getElementById('preset-selector');
            const scoreDisplay = document.getElementById('score-display-container');
            const missingDisplay = document.getElementById('score-missing-container');
            const scoreTotal = document.getElementById('score-total-value');
            const scoreBreakdown = document.getElementById('score-breakdown-value');

            presetSelector.addEventListener('change', function(e) {
                const selectedHash = e.target.value;
                scoreDisplay.style.display = 'none';
                missingDisplay.style.display = 'none';

                if (!selectedHash) return;

                const scoreData = aggregatedScores[selectedHash];
                if (scoreData) {
                    scoreTotal.textContent = parseFloat(scoreData.totalScore).toFixed(4);
                    scoreBreakdown.textContent = JSON.stringify(scoreData.breakdown, null, 2);
                    scoreDisplay.style.display = 'block';
                } else {
                    missingDisplay.style.display = 'block';
                }
            });
        });
    </script>
{% endblock %}
