<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}One Time Draft{% endblock %} — OTD</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏀</text></svg>">

    {# Bootstrap 5 #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    {# Bootstrap Icons #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    {# Custom UI shell #}
    <link rel="stylesheet" href="{{ asset('css/ui.css') }}">
    <link rel="stylesheet" href="{{ asset('css/layout.css') }}">

    {% block stylesheets %}{% endblock %}

    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}
</head>
<body class="otd-body">

    {# ── Sidebar (offcanvas on mobile, fixed on ≥lg) ── #}
    <aside class="otd-sidebar offcanvas-lg offcanvas-start" tabindex="-1" id="otdSidebar" aria-labelledby="otdSidebarLabel">
        <div class="offcanvas-header d-lg-none border-bottom border-secondary-subtle px-3 py-2">
            <span class="offcanvas-title fw-semibold" id="otdSidebarLabel">
                <i class="bi bi-trophy-fill text-warning me-2"></i>One Time Draft
            </span>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#otdSidebar" aria-label="Close"></button>
        </div>
        {% include '_sidebar.html.twig' %}
    </aside>

    {# ── Main wrapper (topbar + content) ── #}
    <div class="otd-wrapper">

        {# ── Topbar ── #}
        <header class="otd-topbar border-bottom border-secondary-subtle">
            {% include '_topbar.html.twig' %}
        </header>

        {# ── Page content ── #}
        <main class="otd-content">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : (type == 'success' ? 'success' : 'info') }} alert-dismissible fade show mb-3" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

    </div>

    {# ── Bootstrap JS ── #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}

</body>
</html>
