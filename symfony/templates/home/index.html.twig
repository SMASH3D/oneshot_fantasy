{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block page_title %}Dashboard{% endblock %}

{% block body %}

<div class="row g-3 mb-4">

    {# Stats cards #}
    <div class="col-6 col-lg-3">
        <div class="card h-100 border-0" style="background:#1a2332;">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="small text-secondary">Active leagues</span>
                    <i class="bi bi-collection-fill text-primary opacity-75"></i>
                </div>
                <div class="fs-4 fw-bold text-white">3</div>
                <div class="small text-secondary mt-1">+1 this month</div>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3">
        <div class="card h-100 border-0" style="background:#1a2332;">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="small text-secondary">Completed drafts</span>
                    <i class="bi bi-lightning-charge-fill text-warning opacity-75"></i>
                </div>
                <div class="fs-4 fw-bold text-white">7</div>
                <div class="small text-secondary mt-1">2 in progress</div>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3">
        <div class="card h-100 border-0" style="background:#1a2332;">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="small text-secondary">Drafted players</span>
                    <i class="bi bi-person-lines-fill text-info opacity-75"></i>
                </div>
                <div class="fs-4 fw-bold text-white">42</div>
                <div class="small text-secondary mt-1">across 15 teams</div>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3">
        <div class="card h-100 border-0" style="background:#1a2332;">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="small text-secondary">Top score</span>
                    <i class="bi bi-bar-chart-fill text-success opacity-75"></i>
                </div>
                <div class="fs-4 fw-bold text-white">128.5</div>
                <div class="small text-secondary mt-1">pts this week</div>
            </div>
        </div>
    </div>

</div>

{# Two-column layout on large screens #}
<div class="row g-3">

    {# Recent activity #}
    <div class="col-12 col-lg-7">
        <div class="card border-0 h-100" style="background:#1a2332;">
            <div class="card-header border-bottom d-flex align-items-center justify-content-between py-3"
                 style="background:transparent; border-color:#2d3a4d !important;">
                <span class="fw-semibold small text-white">Recent activity</span>
                <a href="#" class="small text-secondary text-decoration-none">View all</a>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    {% set events = [
                        {icon: 'lightning-charge-fill', color: 'warning', text: 'NBA Finals draft started',          time: '2h ago'},
                        {icon: 'person-fill-add',       color: 'success', text: 'LeBron James drafted by @smash',    time: '2h ago'},
                        {icon: 'collection-fill',       color: 'primary', text: 'League "All Stars 2025" created',   time: 'yesterday'},
                        {icon: 'bar-chart-fill',        color: 'info',    text: 'Week 14 scores updated',            time: '2 days ago'},
                    ] %}
                    {% for event in events %}
                    <li class="list-group-item border-0 d-flex align-items-center gap-3 py-3 px-4"
                        style="background:transparent; border-bottom:1px solid #2d3a4d !important;">
                        <span class="otd-avatar" style="background:rgba(var(--bs-{{ event.color }}-rgb),.15); color:var(--bs-{{ event.color }});">
                            <i class="bi bi-{{ event.icon }}"></i>
                        </span>
                        <span class="flex-grow-1 small text-white">{{ event.text }}</span>
                        <span class="small text-secondary text-nowrap">{{ event.time }}</span>
                    </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>

    {# Quick links #}
    <div class="col-12 col-lg-5">
        <div class="card border-0" style="background:#1a2332;">
            <div class="card-header border-bottom py-3"
                 style="background:transparent; border-color:#2d3a4d !important;">
                <span class="fw-semibold small text-white">Quick access</span>
            </div>
            <div class="card-body d-flex flex-column gap-2 py-3">
                <a href="#" class="btn btn-sm text-start d-flex align-items-center gap-2"
                   style="background:#0f1419; border-color:#2d3a4d; color:#e7ecf3;">
                    <i class="bi bi-plus-circle-fill text-warning"></i>
                    Create a league
                </a>
                <a href="#" class="btn btn-sm text-start d-flex align-items-center gap-2"
                   style="background:#0f1419; border-color:#2d3a4d; color:#e7ecf3;">
                    <i class="bi bi-lightning-charge-fill text-primary"></i>
                    Join a draft
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('api_doc') }}" target="_blank" rel="noopener"
                   class="btn btn-sm text-start d-flex align-items-center gap-2"
                   style="background:#0f1419; border-color:#2d3a4d; color:#8b9cb3;">
                    <i class="bi bi-code-slash text-info"></i>
                    API documentation
                    <i class="bi bi-box-arrow-up-right ms-auto small opacity-50"></i>
                </a>
                <a href="{{ path('admin') }}" target="_blank" rel="noopener"
                   class="btn btn-sm text-start d-flex align-items-center gap-2"
                   style="background:#0f1419; border-color:#2d3a4d; color:#8b9cb3;">
                    <i class="bi bi-gear-fill text-secondary"></i>
                    Admin panel
                    <i class="bi bi-box-arrow-up-right ms-auto small opacity-50"></i>
                </a>
                {% endif %}
            </div>
        </div>
    </div>

</div>

{% endblock %}
